# Variables used by docker-compose.prod.yml (Ubuntu server on LAN)
POSTGRES_PASSWORD=retro_dev

# First-run admin (created only when postgres_data is empty)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_DISPLAY_NAME=Admin

# Frontend build-time URLs — same ports as dev; use your LAN IP on the server, then rebuild
# Example: VITE_API_URL=http://192.168.1.50:3030/api
#          VITE_FILES_URL=http://192.168.1.50:3030/uploads
VITE_API_URL=http://localhost:3030/api
VITE_FILES_URL=http://localhost:3030/uploads
