# Variables used by docker-compose.prod.yml (production stack)
POSTGRES_PASSWORD=retro_dev

# First-run admin (created only when postgres_data is empty)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_DISPLAY_NAME=Admin

# Caddy / public URLs
DOMAIN=localhost
ACME_EMAIL=dev@localhost

# Frontend build-time URLs (used when building production images)
# Production (behind Caddy): https://<your-domain>/api and /uploads
# VITE_API_URL=https://example.com/api
# VITE_FILES_URL=https://example.com/uploads
#
# Local (HTTP override): http://localhost:4567/api and /uploads
VITE_API_URL=http://localhost:4567/api
VITE_FILES_URL=http://localhost:4567/uploads
